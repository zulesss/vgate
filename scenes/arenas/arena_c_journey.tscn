; ─────────────────────────────────────────────────────────────────────────────
; NAVIGATION — single region across all floors. NavBaker bake на _ready().
; agent_radius=0.3 / max_climb=0.3 — same как arena_b/a defaults. flat geometry,
; no multi-tier (Arena C shaft pivot — see brief).

[node name="NavigationRegion3D" type="NavigationRegion3D" parent="."]
navigation_mesh = SubResource("NavMesh_journey")

[node name="NavBaker" type="Node" parent="." node_paths=PackedStringArray("region")]
script = ExtResource("1_navbaker")
region = NodePath("../NavigationRegion3D")

; ─────────────────────────────────────────────────────────────────────────────
; SPAWN POINTS — required by SpawnController._ready() (warning if empty).
; Journey arena dynamic spawns disabled, но controller всё равно reads group
; чтобы push_warning не флудил. Один dummy marker (origin) удовлетворяет contract.

[node name="SpawnPoints" type="Node3D" parent="."]

[node name="S1" type="Marker3D" parent="SpawnPoints" groups=["spawn_point"]]
